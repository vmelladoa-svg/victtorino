generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoComerciante {
  pendiente
  aprobado
  rechazado
}

enum EstadoPedido {
  pago_en_validacion
  validado
  oc_generada
  despachado
  entregado
  rechazado
}

model Comerciante {
  id         String            @id @default(cuid())
  nombre     String
  email      String            @unique
  clave      String
  rutEmpresa String
  giro       String
  telefono   String
  comuna     String?
  region     String?
  estado     EstadoComerciante @default(pendiente)
  pedidos    Pedido[]
  createdAt  DateTime          @default(now())

  // Evaluación de cliente (híbrida: score automático + ajuste manual del admin)
  scoreAjuste Int       @default(0) // ajuste manual del admin sobre el score automático (-100..100)
  tierManual  String?               // tier fijado a mano por el admin (A/B/C); null = usar el derivado del score
  notaEval    String?               // notas de evaluación del admin
  evaluadoAt  DateTime?             // última vez que el admin evaluó/ajustó
}

model Producto {
  id          String       @id @default(cuid())
  codigoAlila String       @unique
  nombre      String
  categoria   String?
  costo       Int?
  precioT1    Int?
  precioT2    Int?
  precioT3    Int?
  unidCaja    Int?
  minCompra   Int          @default(1)
  fotoUrl     String?
  fotos       String[]     // todas las fotos del producto (de AlilaTop)
  descripcion String?      // HTML de la descripcion (de AlilaTop)
  dimensiones String?      // ej "17X9X17"
  embalaje    String?      // ej "caja de color"
  keywords    String?      // palabras clave para la publicacion
  nArticulo   String?      // N° de articulo de AlilaTop
  codigoProveedor String?  // codigo del proveedor/fabrica (para la OC)
  link1688    String?
  linkML      String?      // referencia precio mercado ML
  activo      Boolean      @default(true)
  stock       Int?         // unidades disponibles en AlilaTop (lo actualiza el refresco; sin stock = no se ofrece)
  reservado   Int          @default(0) // unidades reservadas por pedidos con pago validado, aun no despachados
  items       PedidoItem[]
}

model Pedido {
  id             String       @id @default(cuid())
  comerciante    Comerciante  @relation(fields: [comercianteId], references: [id])
  comercianteId  String
  estado         EstadoPedido @default(pago_en_validacion)
  total          Int
  region         String
  direccion      String
  comprobanteUrl String?
  transportista  String?
  tracking       String?
  items          PedidoItem[]
  oc             OC?
  createdAt      DateTime     @default(now())
}

model PedidoItem {
  id             String   @id @default(cuid())
  pedido         Pedido   @relation(fields: [pedidoId], references: [id])
  pedidoId       String
  producto       Producto @relation(fields: [productoId], references: [id])
  productoId     String
  cantidad       Int
  precioAplicado Int
  subtotal       Int
}

// Contador de ventana fija para rate-limit de login/registro (store compartido en
// vez de Upstash: reusa la base que ya existe). key = "login:<ip>" / "registro:<ip>".
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}

model OC {
  id        String   @id @default(cuid())
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])
  pedidoId  String   @unique
  proveedor String   @default("AlilaTop")
  numeroOc  String   @unique
  estado    String   @default("emitida")
  createdAt DateTime @default(now())
}
